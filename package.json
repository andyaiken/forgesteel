		"antd": "^6.3.7",
		"axios": "^1.16.0",
		"html2canvas": "^1.4.1",
		"jspdf": "^4.2.1",
		"localforage": "^1.10.0",
		"modern-screenshot": "^4.7.0",
		"pdf-lib": "^1.17.1",
		"react": "^19.2.6",
		"react-dom": "^19.2.6",
		"react-router": "^7.15.0",
		"sass": "^1.99.0",
		"showdown": "^2.1.0"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@stylistic/eslint-plugin": "^5.10.0",
		"@types/gtag.js": "^0.0.20",
