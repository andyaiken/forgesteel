		"@vitejs/plugin-react": "^6.0.1",
		"@vitest/coverage-v8": "^4.1.5",
		"axios-mock-adapter": "^2.1.0",
		"esbuild": "^0.28.0",
		"eslint": "^10.3.0",
		"globals": "^17.6.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.2",
		"vite": "^8.0.11",
		"vitest": "^4.1.5"
	}
