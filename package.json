{
	"name": "forgesteel",
	"private": true,
	"version": "12.168.0",
	"type": "module",
	"repository": "https://github.com/andyaiken/forgesteel.git",
	"homepage": "https://andyaiken.github.io/forgesteel/",
	"scripts": {
		"start": "npm ci && vite --host",
		"update": "npx npm-check-updates --peer --interactive --format group",
		"lint": "eslint \"src/**/*.{ts,tsx}\" --concurrency auto",
		"fix": "eslint \"src/**/*.{ts,tsx}\" --concurrency auto --fix",
		"test": "vitest",
		"check": "npm run lint && tsc -p tsconfig.json && vitest run && npm audit",
		"build": "vite build",
		"predeploy": "npm run check && npm run build",
		"deploy": "gh-pages -d dist"
	},
	"dependencies": {
		"@ant-design/icons": "^6.1.0",
		"@dnd-kit/core": "^6.3.1",
		"@mdxeditor/editor": "^3.53.1",
		"@types/showdown": "^2.0.6",
		"antd": "^6.3.4",
		"axios": "^1.13.6",
		"gh-pages": "^6.3.0",
		"html2canvas": "^1.4.1",
		"jspdf": "^4.2.1",
		"localforage": "^1.10.0",
		"modern-screenshot": "^4.6.8",
		"pdf-lib": "^1.17.1",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-router": "^7.13.2",
		"sass": "^1.98.0",
		"showdown": "^2.1.0"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@stylistic/eslint-plugin": "^5.10.0",
		"@types/gtag.js": "^0.0.20",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"@vitest/coverage-v8": "^4.1.1",
		"axios-mock-adapter": "^2.1.0",
		"esbuild": "^0.27.4",
		"eslint": "^10.1.0",
		"globals": "^17.4.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.2",
		"vite": "^8.0.3",
		"vitest": "^4.1.1"
	}
}
